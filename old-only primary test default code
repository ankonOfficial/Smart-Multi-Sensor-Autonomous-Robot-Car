// Motor Pins
#define IN1 2
#define IN2 3
#define IN3 12
#define IN4 13
#define ENA 10
#define ENB 11

void setup() {
  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  pinMode(ENA, OUTPUT);
  pinMode(ENB, OUTPUT);

  Serial.begin(9600);
  Serial.println("Forward FIXED Test...");
}

void loop() {

  // ===== Forward (FIXED) =====

  // Motor A (Left)
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);

  // Motor B (Right) --> REVERSED
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);

  analogWrite(ENA, 200);
  analogWrite(ENB, 200);

  Serial.println("Moving Straight Forward...");
}


// FOR ARDINO ,BAZER, SERVO,  Ultrasonic
#include <Servo.h>

Servo myServo;

#define trigPin 7
#define echoPin 6
#define buzzer 8

long duration;
int distance;

void setup() {
  myServo.attach(9);     
  pinMode(trigPin, OUTPUT);
  pinMode(echoPin, INPUT);
  pinMode(buzzer, OUTPUT);
  Serial.begin(9600);
}

// Function: read distance with noise filter
int getDistance() {
  digitalWrite(trigPin, LOW);
  delayMicroseconds(2);

  digitalWrite(trigPin, HIGH);
  delayMicroseconds(10);
  digitalWrite(trigPin, LOW);

  duration = pulseIn(echoPin, HIGH, 30000); // 30ms timeout
  if(duration == 0) return 999;             // invalid reading

  return duration * 0.034 / 2;
}

// Function: check distance and control buzzer
void distanceCheck() {
  int total = 0;
  int count = 5; // average of 5 readings
  for(int i = 0; i < count; i++) {
    total += getDistance();
    delay(5);
  }
  distance = total / count;

  Serial.println(distance);

  if(distance > 0 && distance < 20) { // object detected
    digitalWrite(buzzer, HIGH);
  } else {
    digitalWrite(buzzer, LOW);
  }
}

void loop() {
  // Servo sweep from 0° → 90°
  for(int pos = 0; pos <= 90; pos += 1) {
    myServo.write(pos);
    delay(15); // smaller delay → smoother
    distanceCheck(); 
  }

  // Servo sweep back 90° → 0°
  for(int pos = 90; pos >= 0; pos -= 1) {
    myServo.write(pos);
    delay(15);
    distanceCheck();
  }
}
